---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Tecnologias from '../../components/Tecnologias.astro';
import Proyectos from '../../components/Proyectos.astro';
import Experiencia from '../../components/Experiencia.astro';
import About from '../../components/About.astro';
import Contacto from '../../components/Contacto.astro';
import { en } from '../../i18n/en';
---

<Layout>
  <div class="container-viajero">
    <canvas id="trail-canvas"></canvas>
    <div class="viajero-node" id="viajero"></div>
  </div>
  <Header />
  <Hero
    subtitle={en.hero_subtitle}
    description={en.hero_description}
    btn_linkedin={en.hero_btn_linkedin}
    btn_cv={en.hero_btn_cv}
    cv_path={en.cv_path}
  />
  <Tecnologias
    title={en.tecnologias_title}
    description={en.tecnologias_description}
  />
  <Proyectos title={en.proyectos_title} descriptions={en.projects} />
  <Experiencia title={en.experiencia_title} descriptions={en.experiences} />
  <About
    title={en.about.title}
    subtitle={en.about.subtitle}
    paragraphs={en.about.paragraphs}
    btn_cv={en.about.btn_cv}
    cv_path={en.about.cv_path}
  />
  <Contacto
    title={en.contacto_title}
    subtitle={en.contacto_subtitle}
    btn_email={en.contacto_btn_email}
    description={en.contacto_description}
    formulario_nombre={en.contacto_fomulario_nombre}
    formulario_email={en.contacto_fomulario_email}
    formulario_mensaje={en.contacto_fomulario_mensaje}
  />
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // ── LENIS ──────────────────────────────────────────────────
  const lenis = new Lenis({ lerp: 0.08 });

  lenis.on('scroll', ScrollTrigger.update);

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  gsap.ticker.lagSmoothing(0);

  // Color por sección — ajusta los IDs a los tuyos
  const SECTION_COLORS: Record<string, string> = {
    hero: '#ffffff',
    tecnologias: '#7b6ef5', // tu primary
    proyectos: '#5dcaa5', // teal
    experiencia: '#ef9f27', // amber
    about: '#f0997b', // coral
    contacto: '#ffffff',
  };

  function iniciarViajero() {
    const viajero = document.getElementById('viajero') as HTMLElement;
    const canvas = document.getElementById('trail-canvas') as HTMLCanvasElement;
    if (!viajero || !canvas) return;

    const ctx = canvas.getContext('2d')!;

    // Canvas ocupa toda la ventana (fixed)
    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // ── Trail: historial de posiciones ─────────────────────
    const TRAIL_LENGTH = 28;
    const trail: { x: number; y: number }[] = [];
    let currentColor = '#ffffff';
    let targetColor = '#ffffff';
    let animFrame: number;

    function lerpColor(a: string, b: string, t: number): string {
      const parse = (c: string) => [
        parseInt(c.slice(1, 3), 16),
        parseInt(c.slice(3, 5), 16),
        parseInt(c.slice(5, 7), 16),
      ];
      const [ar, ag, ab] = parse(a);
      const [br, bg, bb] = parse(b);
      const r = Math.round(ar + (br - ar) * t);
      const g = Math.round(ag + (bg - ag) * t);
      const b_ = Math.round(ab + (bb - ab) * t);
      return `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${b_.toString(16).padStart(2, '0')}`;
    }

    function hexToRgb(hex: string) {
      return {
        r: parseInt(hex.slice(1, 3), 16),
        g: parseInt(hex.slice(3, 5), 16),
        b: parseInt(hex.slice(5, 7), 16),
      };
    }

    function drawTrail() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Interpolar color suavemente
      currentColor = lerpColor(currentColor, targetColor, 0.06);
      const { r, g, b } = hexToRgb(currentColor);

      for (let i = 1; i < trail.length; i++) {
        const alpha = (i / trail.length) * 0.55;
        const size = (i / trail.length) * 7;

        ctx.beginPath();
        ctx.arc(trail[i].x, trail[i].y, size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
        ctx.fill();
      }

      // Glow del nodo principal
      if (trail.length > 0) {
        const last = trail[trail.length - 1];
        const grad = ctx.createRadialGradient(
          last.x,
          last.y,
          0,
          last.x,
          last.y,
          28,
        );
        grad.addColorStop(0, `rgba(${r},${g},${b},0.35)`);
        grad.addColorStop(1, `rgba(${r},${g},${b},0)`);
        ctx.beginPath();
        ctx.arc(last.x, last.y, 28, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }

      animFrame = requestAnimationFrame(drawTrail);
    }

    drawTrail();

    // ── Detección de sección activa ────────────────────────
    function getSectionColor(): string {
      const sections = Object.keys(SECTION_COLORS);
      for (const id of sections) {
        const el = document.getElementById(id);
        if (!el) continue;
        const rect = el.getBoundingClientRect();
        if (
          rect.top <= window.innerHeight * 0.5 &&
          rect.bottom >= window.innerHeight * 0.5
        ) {
          return SECTION_COLORS[id];
        }
      }
      return '#ffffff';
    }

    // ── Pulso "latido" cuando no scrollea ──────────────────
    let pulseAnim = gsap.to(viajero, {
      scale: 1.6,
      opacity: 0.5,
      duration: 1.1,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      paused: false,
    });

    let scrollTimeout: ReturnType<typeof setTimeout>;

    // ── ScrollTrigger principal ────────────────────────────
    gsap.to(
      {},
      {
        ease: 'none',
        scrollTrigger: {
          trigger: 'body',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.8,
          onUpdate: (self) => {
            const p = self.progress;

            // Coordenadas en el DOCUMENTO (no viewport)
            const docH = document.documentElement.scrollHeight;
            const anchoTotal = window.innerWidth;
            const amplitud = anchoTotal * 0.75;
            const offset = (anchoTotal - amplitud) / 2;
            const frecuencia = 4;

            const xDoc =
              offset +
              (Math.sin(p * Math.PI * frecuencia) + 1) * (amplitud / 2);
            const yDoc = p * docH; // posición absoluta en el documento

            // Convertimos a posición en el VIEWPORT (fixed canvas)
            const yViewport = yDoc - window.scrollY;

            // Actualizar posición del nodo
            gsap.set(viajero, { x: xDoc, y: yViewport });

            // Agregar al trail
            trail.push({ x: xDoc, y: yViewport });
            if (trail.length > TRAIL_LENGTH) trail.shift();

            // Color según sección
            targetColor = getSectionColor();

            // Detener pulso mientras scrollea, reanudar al parar
            pulseAnim.pause();
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => pulseAnim.play(), 800);

            trail.push({ x: xDoc, y: yViewport });
            if (trail.length > TRAIL_LENGTH) trail.shift();

            // Al parar: vaciar trail y reanudar pulso
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
              // Vaciar gradualmente el trail
              const fadeTrail = setInterval(() => {
                trail.shift();
                if (trail.length === 0) clearInterval(fadeTrail);
              }, 30);

              pulseAnim.play();
            }, 150);
          },
        },
      },
    );

    // Cleanup en navegación de Astro
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animFrame);
      ScrollTrigger.getAll().forEach((t) => t.kill());
    });
  }

  window.addEventListener('load', iniciarViajero);
  document.addEventListener('astro:page-load', iniciarViajero);
</script>

<style>
  .container-viajero {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
  }

  #trail-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .viajero-node {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
    box-shadow:
      0 0 8px currentColor,
      0 0 20px currentColor;
  }
</style>
