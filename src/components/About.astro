---
import foto from '../assets/juan.png';

interface Props {
  title: string;
  subtitle: string;
  paragraphs: string[];
  btn_cv: string;
  cv_path: string;
}
const { title, subtitle, paragraphs, btn_cv, cv_path } = Astro.props;
---

<section id="sobre-mi" class="py-20 px-6 relative">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Título -->
    <div class="text-start mb-16">
      <h2 class="about-title text-4xl md:text-5xl font-bold text-blanco">
        {title}
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Texto -->
      <div class="about-card">
        <div class="bg-negro-claro p-8 md:p-12 shadow-[8px_8px_0_black]">
          <h3
            class="about-subtitle text-2xl md:text-3xl font-bold text-secondary mb-6"
          >
            {subtitle}
          </h3>

          <div class="space-y-4">
            {
              paragraphs.map((p) => (
                <p class="about-line text-gris-claro text-lg leading-relaxed">
                  {p}
                </p>
              ))
            }
          </div>

          <div class="mt-8">
            <a
              href={cv_path}
              download="CV_JuanHoyos.pdf"
              class="about-btn inline-block px-6 py-3 bg-primary text-blanco font-medium border-2 border-black shadow-[4px_4px_0_black]"
            >
              {btn_cv}
            </a>
          </div>
        </div>
      </div>

      <!-- Imagen -->
      <div class="about-image-wrap">
        <div class="about-image w-full h-96 md:h-125">
          <canvas id="model-canvas" class="w-full h-full"></canvas>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  // @ts-ignore
  import * as THREE from 'three';
  // @ts-ignore
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { animateSectionTitleScroll } from '../util/animations';

  gsap.registerPlugin(ScrollTrigger);

  function initAbout() {
    animateSectionTitleScroll('.about-title', '#sobre-mi');

    // ── Three.js setup ──────────────────────────────────────────
    const canvas = document.getElementById('model-canvas') as HTMLCanvasElement;
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      45,
      canvas.clientWidth / canvas.clientHeight,
      0.1,
      100,
    );

    // Iluminación
    scene.add(new THREE.AmbientLight(0xffffff, 3));

    // Luz frontal principal
    const frontLight = new THREE.DirectionalLight(0xffffff, 3);
    frontLight.position.set(0, 2, 5);
    scene.add(frontLight);

    // Luz desde arriba
    const topLight = new THREE.DirectionalLight(0xffffff, 2);
    topLight.position.set(0, 10, 0);
    scene.add(topLight);

    // Luz de relleno desde la izquierda (elimina sombras duras)
    const fillLight = new THREE.DirectionalLight(0xffffff, 1.5);
    fillLight.position.set(-5, 0, 3);
    scene.add(fillLight);

    // Luz de relleno desde la derecha
    const rimLight = new THREE.DirectionalLight(0xffffff, 1.5);
    rimLight.position.set(5, 0, 3);
    scene.add(rimLight);

    // ── Estado del mouse ────────────────────────────────────────
    let targetRotX = 0;
    let targetRotY = 0;
    let model: THREE.Group | null = null;

    document.addEventListener('mousemove', (e) => {
      const x = (e.clientY / window.innerHeight - 0.5) * 2;
      const y = (e.clientX / window.innerWidth - 0.5) * 2;
      targetRotX = x * 0.3;
      targetRotY = y * 0.5;
    });

    // ── Carga del modelo ────────────────────────────────────────
    const loader = new GLTFLoader();
    loader.load('juan-3d.glb', (gltf: any) => {
      model = gltf.scene as THREE.Group;

      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());
      model.position.sub(center);

      scene.add(model);

      // Ajustar cámara al tamaño real del modelo
      const maxDim = Math.max(size.x, size.y, size.z);
      const fov = camera.fov * (Math.PI / 180);
      camera.position.z = (maxDim / 2 / Math.tan(fov / 2)) * 1.2;
      camera.updateProjectionMatrix();
    });

    // ── Loop con seguimiento suave del mouse ────────────────────
    renderer.setAnimationLoop(() => {
      if (model) {
        // Lerp: persigue el objetivo suavemente
        model.rotation.x += (targetRotX - model.rotation.x) * 0.05;
        model.rotation.y += (targetRotY - model.rotation.y) * 0.05;
      }
      renderer.render(scene, camera);
    });

    // ── Responsivo ──────────────────────────────────────────────
    const ro = new ResizeObserver(() => {
      renderer.setSize(canvas.clientWidth, canvas.clientHeight);
      camera.aspect = canvas.clientWidth / canvas.clientHeight;
      camera.updateProjectionMatrix();
    });
    ro.observe(canvas);

    // ── Animaciones GSAP ────────────────────────────────────────
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#sobre-mi',
        start: 'top 75%',
        toggleActions: 'play none none reset',
      },
    });

    tl.from('.about-subtitle', {
      y: 20,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });

    tl.from(
      '.about-line',
      {
        y: 25,
        opacity: 0,
        stagger: 0.18,
        duration: 0.75,
        ease: 'power3.out',
      },
      '-=0.4',
    );

    tl.from(
      '.about-btn',
      {
        y: 20,
        opacity: 0,
        duration: 0.6,
        ease: 'back.out(1.7)',
      },
      '-=0.3',
    );

    tl.from(
      '.about-image',
      {
        x: 80,
        opacity: 0,
        duration: 1,
        ease: 'power3.out',
      },
      '-=1',
    );

    // Flotación constante
    gsap.to('.about-image-wrap', {
      y: -12,
      duration: 2.8,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
    });
  }

  document.addEventListener('astro:page-load', initAbout);
  initAbout();
</script>

<style>
  .about-image,
  .about-line,
  .about-title {
    will-change: transform, opacity;
  }
</style>
