---
import { Icon } from 'astro-icon/components';
import { experiences } from '../data/experiences';
interface Props {
  title: string;
  descriptions: Record<string, string>;
}
const { title, descriptions } = Astro.props;

const experiencesWithDesc = experiences.map((e) => ({
  ...e,
  description: descriptions[e.id] ?? '',
}));
---

<section id="experiencia" class="min-h-screen py-20 px-6 relative">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Título -->
    <h2 class="timeline-title text-blanco mb-16 text-start">
      {title}
    </h2>

    <!-- Timeline -->
    <div class="relative">
      <!-- Línea animada -->
      <div class="timeline-line bg-linear-to-b from-primary via-primary to-transparent absolute left-5 md:left-1/2 top-0 -translate-x-1/2 w-1 h-full origin-top bg-primary"></div>

      <div class="space-y-12">
        {
          experiencesWithDesc.map((exp, index) => {
            const isLeft = index % 2 === 0;

            return (
              <article
                class={`timeline-item relative flex flex-col md:items-center md:gap-8 ${
                  isLeft ? 'md:flex-row' : 'md:flex-row-reverse'
                }`}
              >
                <!-- Punto/Icono desktop -->
                <div class="hidden md:block absolute left-1/2 -translate-x-1/2 z-10">
                  <div
                    class="timeline-dot w-16 h-16 rounded-full border-4 border-black flex items-center justify-center shadow-[4px_4px_0_black]"
                    style={`background:${exp.color}`}
                  >
                    <Icon name={exp.icon} class="w-7 h-7 text-white" />
                  </div>
                </div>

                <!-- Punto mobile -->
                <div class="absolute left-0 top-6 md:hidden z-10">
                  <div
                    class="timeline-dot w-10 h-10 rounded-full border-2 border-black flex items-center justify-center"
                    style={`background:${exp.color}`}
                  >
                    <Icon name={exp.icon} class="w-5 h-5 text-white" />
                  </div>
                </div>

                <!-- Card -->
                <div class="w-full md:w-[calc(50%-4rem)] pl-14 md:pl-0 flex justify-end">
                  <div
                    class="timeline-card group w-full p-6 border-4 border-black bg-negro-claro
                           shadow-[6px_6px_0_black] transition-all duration-300"
                  >
                    <h3 class="text-blanco mb-1">{exp.title}</h3>

                    <p class="text-secondary mb-3">{exp.organization}</p>

                    <div class="inline-block px-3 py-1 mb-4 border-2 border-borde bg-primary text-sm">
                      <span class="text-blanco">{exp.period}</span>
                    </div>

                    <p class="text-gris-claro">{exp.description}</p>
                  </div>
                </div>

                <!-- Espacio -->
                <div class="hidden md:block w-[calc(50%-4rem)]"></div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { animateSectionTitleScroll } from '../util/animations';

  gsap.registerPlugin(ScrollTrigger);

  function initTimeline() {
    const items = gsap.utils.toArray<HTMLElement>('.timeline-item');
    const cards = gsap.utils.toArray<HTMLElement>('.timeline-card');
    const dots = gsap.utils.toArray<HTMLElement>('.timeline-dot');

    if (!items.length) return;

    // Animar título con función utilitaria
    animateSectionTitleScroll('.timeline-title', '#experiencia');

    // Línea dibujándose
   gsap.fromTo(
      '.timeline-line',
      {
        scaleY: 0,
        transformOrigin: 'top top',
      },
      {
        scaleY: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: '#experiencia',
          start: 'top 80%',
          end: 'bottom 85%',
          scrub: true,
        },
      }
    );

    // Puntos
    dots.forEach((dot) => {
  gsap.from(dot, {
    scale: 0,
    opacity: 0,
    duration: 0.45,
    ease: 'back.out(2)',
    scrollTrigger: {
      trigger: dot,
      start: 'top 78%',
      toggleActions: 'play none none reverse',
    },
  });
});

    // Cards alternadas
    cards.forEach((card, i) => {
      gsap.from(card, {
        x: i % 2 === 0 ? -70 : 70,
        y: 20,
        opacity: 0,
        filter: 'blur(10px)',
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
          toggleActions: 'play none none reset',
        },
      });

      // Hover premium
      card.addEventListener('mouseenter', () => {
        gsap.to(card, {
          y: -6,
          boxShadow: '10px 10px 0 black',
          duration: 0.25,
          ease: 'power2.out',
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          y: 0,
          boxShadow: '6px 6px 0 black',
          duration: 0.25,
          ease: 'power2.out',
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTimeline);
  } else {
    initTimeline();
  }
</script>